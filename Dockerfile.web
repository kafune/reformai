# syntax=docker/dockerfile:1.7
FROM oven/bun:1.3.10 AS base
WORKDIR /app

# ─── deps ──────────────────────────────────────────────────────
# Instala todas as dependências (root + workspace node_modules)
# com apenas os package.json presentes — sem código-fonte.
FROM base AS deps
COPY package.json bun.lock turbo.json ./
COPY apps/web/package.json ./apps/web/package.json
COPY packages/database/package.json ./packages/database/package.json
COPY packages/templates/package.json ./packages/templates/package.json
RUN bun install --frozen-lockfile

# ─── build ─────────────────────────────────────────────────────
FROM base AS build
ENV NEXT_TELEMETRY_DISABLED=1

# Copia /app inteiro do estágio deps — preserva root + workspace node_modules
# (incluindo node_modules/.bun que contém os packages reais via symlink).
# COPY . . apenas sobrepõe o código-fonte (node_modules excluído por .dockerignore).
COPY --from=deps /app ./
COPY . .

# Gera o Prisma client e faz o build do Next.js
RUN bun run --cwd packages/database db:generate
RUN bun run --cwd apps/web build

# ─── runtime ───────────────────────────────────────────────────
FROM base AS runtime
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000

# Standalone output is self-contained; static assets and public must be added separately.
COPY --from=build /app/apps/web/.next/standalone ./
COPY --from=build /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=build /app/apps/web/public ./apps/web/public

# Migration step needs the database package and its Prisma CLI.
COPY --from=build /app/packages/database ./packages/database

EXPOSE 3000

# Migrações idempotentes antes do servidor
CMD ["sh", "-c", "bun run --cwd packages/database db:migrate:deploy && node apps/web/server.js"]
