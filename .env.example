DATABASE_URL=postgresql://reformai:reformai_dev@localhost:5433/reformai
REDIS_URL=redis://localhost:6379
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000
ANTHROPIC_API_KEY=

# Modelos Claude por finalidade (todos opcionais — defaults entre parênteses).
# ANTHROPIC_MODEL: default geral da plataforma (claude-sonnet-4-6)
# ANTHROPIC_MODEL_EXTRACTION: extração de campos de documentos (claude-haiku-4-5)
# ANTHROPIC_MODEL_ANALYSIS: análise cruzada de documentos (claude-sonnet-4-6)
# ANTHROPIC_MODEL_PHOTOS: documentos do tipo PHOTOS — precisão extra (= ANALYSIS)
# ANTHROPIC_MODEL=
# ANTHROPIC_MODEL_EXTRACTION=
# ANTHROPIC_MODEL_ANALYSIS=
# ANTHROPIC_MODEL_PHOTOS=
STORAGE_ADAPTER=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=reformai
MINIO_SECRET_KEY=reformai_dev
MINIO_BUCKET=reformai
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email transacional (reset de senha, convites, notificações).
# Provedor escolhido automaticamente: SMTP (se SMTP_HOST) > Resend (se RESEND_API_KEY) > nenhum.
# Forçar um deles: EMAIL_PROVIDER=smtp | resend. Em branco = envio desativado (in-app segue ok).
EMAIL_PROVIDER=
EMAIL_FROM=ReformAI <noreply@seudominio.com.br>

# Opção A — SMTP próprio na VPS (Postfix, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false          # true para porta 465 (TLS implícito); 587 usa STARTTLS
SMTP_USER=
SMTP_PASS=

# Opção B — Resend (https://resend.com)
RESEND_API_KEY=

# Web Push (notificações do navegador). Gere as chaves com:
#   bunx web-push generate-vapid-keys --json
# Deixar em branco desativa o push; in-app e e-mail continuam funcionando.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@seudominio.com.br

# Monitoramento de erros (opcional). Compatível com Sentry SaaS ou self-hosted
# (ex.: GlitchTip). Em branco = desativado (captureException vira no-op).
SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0      # 0..1 — amostragem de tracing (custo)
# APP_RELEASE=                     # tag de release (ex.: short SHA) para agrupar erros

# RAG de normas (busca semântica). Embeddings NATIVOS e locais via transformers.js
# (ONNX), sem API externa nem custo — baixa o modelo (~100MB) no 1º uso.
# Ingerir normas: DATABASE_URL=... bun run --cwd apps/web seed:norms
# EMBEDDINGS_MODEL: modelo de feature-extraction (default multilíngue, 384 dims).
# EMBEDDINGS_PROVIDER=deterministic força o stub offline (CI/testes), sem semântica.
EMBEDDINGS_MODEL=Xenova/paraphrase-multilingual-MiniLM-L12-v2
# EMBEDDINGS_PROVIDER=deterministic
