DATABASE_URL=postgresql://reformai:reformai_dev@localhost:5433/reformai
REDIS_URL=redis://localhost:6379
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000
ANTHROPIC_API_KEY=
STORAGE_ADAPTER=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=reformai
MINIO_SECRET_KEY=reformai_dev
MINIO_BUCKET=reformai
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (transacional via Resend — https://resend.com)
# Deixar em branco desativa envio de email; notificações in-app continuam funcionando.
RESEND_API_KEY=
EMAIL_FROM=ReformAI <noreply@seudominio.com.br>

# Web Push (notificações do navegador). Gere as chaves com:
#   bunx web-push generate-vapid-keys --json
# Deixar em branco desativa o push; in-app e e-mail continuam funcionando.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@seudominio.com.br

# RAG de normas (busca semântica). Embeddings NATIVOS e locais via transformers.js
# (ONNX), sem API externa nem custo — baixa o modelo (~100MB) no 1º uso.
# Ingerir normas: DATABASE_URL=... bun run --cwd apps/web seed:norms
# EMBEDDINGS_MODEL: modelo de feature-extraction (default multilíngue, 384 dims).
# EMBEDDINGS_PROVIDER=deterministic força o stub offline (CI/testes), sem semântica.
EMBEDDINGS_MODEL=Xenova/paraphrase-multilingual-MiniLM-L12-v2
# EMBEDDINGS_PROVIDER=deterministic
