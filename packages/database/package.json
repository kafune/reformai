{
  "name": "@reformai/database",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "db:generate": "bunx prisma@6.19.3 generate",
    "db:migrate": "bunx prisma@6.19.3 migrate dev",
    "db:migrate:deploy": "bunx prisma@6.19.3 migrate deploy",
    "db:seed": "bun run prisma/seed.ts",
    "db:create-admin": "bun run prisma/create-admin.ts",
    "db:studio": "bunx prisma@6.19.3 studio",
    "db:reset": "bunx prisma@6.19.3 migrate reset --force"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0"
  },
  "devDependencies": {
    "prisma": "^6.6.0",
    "@types/bun": "latest"
  },
  "exports": {
    ".": {
      "require": "./generated/client/index.js",
      "import": "./generated/client/index.js",
      "types": "./generated/client/index.d.ts"
    }
  }
}
