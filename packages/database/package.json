{
  "name": "@reformai/database",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "db:generate": "./node_modules/.bin/prisma generate",
    "db:migrate": "./node_modules/.bin/prisma migrate dev",
    "db:migrate:deploy": "./node_modules/.bin/prisma migrate deploy",
    "db:seed": "bun run prisma/seed.ts",
    "db:create-admin": "bun run prisma/create-admin.ts",
    "db:studio": "./node_modules/.bin/prisma studio",
    "db:reset": "./node_modules/.bin/prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0"
  },
  "devDependencies": {
    "prisma": "^6.6.0",
    "@types/bun": "latest"
  },
  "exports": {
    ".": {
      "require": "./generated/client/index.js",
      "import": "./generated/client/index.js",
      "types": "./generated/client/index.d.ts"
    }
  }
}
